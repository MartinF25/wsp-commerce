                      "parameters":  {
                                         "jsCode":  "// Fokus: kleine, gut versendbare Solar-Zubehoerteile\n// URL-Format: /s-multimedia-elektronik/sonstiges/{slug}/k0c168\nconst BASE = \u0027https://www.kleinanzeigen.de/s-multimedia-elektronik/sonstiges/\u0027;\nconst SUFFIX = \u0027/k0c168\u0027;\n\nconst keywords = [\n  // WECHSELRICHTER – HOCH (leicht, gut versendbar, hohe Marge)\n  { keyword: \u0027Hoymiles\u0027, slug: \u0027hoymiles\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Deye Wechselrichter\u0027, slug: \u0027deye-wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Growatt Wechselrichter\u0027, slug: \u0027growatt-wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Goodwe Wechselrichter\u0027, slug: \u0027goodwe-wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Huawei SUN2000\u0027, slug: \u0027huawei-sun2000\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027SMA Wechselrichter\u0027, slug: \u0027sma-wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Sungrow\u0027, slug: \u0027sungrow\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Fronius\u0027, slug: \u0027fronius\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Solax Wechselrichter\u0027, slug: \u0027solax-wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Mikrowechselrichter\u0027, slug: \u0027mikrowechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  // LADEREGLER – HOCH (klein, leicht, gute Marge)\n  { keyword: \u0027Victron MPPT\u0027, slug: \u0027victron-mppt\u0027, category: \u0027laderegler\u0027 },\n  { keyword: \u0027MPPT Laderegler\u0027, slug: \u0027mppt-laderegler\u0027, category: \u0027laderegler\u0027 },\n  { keyword: \u0027EPever Laderegler\u0027, slug: \u0027epever-laderegler\u0027, category: \u0027laderegler\u0027 },\n  { keyword: \u0027Solarladeregler\u0027, slug: \u0027solarladeregler\u0027, category: \u0027laderegler\u0027 },\n  // OPTIMIZER – MITTEL\n  { keyword: \u0027SolarEdge Optimizer\u0027, slug: \u0027solaredge-optimizer\u0027, category: \u0027optimizer\u0027 },\n  { keyword: \u0027Tigo Optimizer\u0027, slug: \u0027tigo-optimizer\u0027, category: \u0027optimizer\u0027 },\n  { keyword: \u0027Leistungsoptimierer\u0027, slug: \u0027leistungsoptimierer\u0027, category: \u0027optimizer\u0027 },\n  // HALTERUNGEN – MITTEL\n  { keyword: \u0027Solarmodul Halterung\u0027, slug: \u0027solarmodul-halterung\u0027, category: \u0027halterung\u0027 },\n  { keyword: \u0027Solar Aufstaenderung\u0027, slug: \u0027solar-aufstaenderung\u0027, category: \u0027halterung\u0027 },\n  { keyword: \u0027PV Halterung\u0027, slug: \u0027pv-halterung\u0027, category: \u0027halterung\u0027 },\n  // BESTAND\n  { keyword: \u0027Solarzaun\u0027, slug: \u0027solarzaun\u0027, category: \u0027solarzaun\u0027 },\n  { keyword: \u0027Victron Energy\u0027, slug: \u0027victron-energy\u0027, category: \u0027solarspeicher\u0027 },\n  { keyword: \u0027Pylontech\u0027, slug: \u0027pylontech\u0027, category: \u0027solarspeicher\u0027 },\n];\n\nreturn keywords.map(k =\u003e ({\n  json: {\n    keyword: k.keyword,\n    category: k.category,\n    searchUrl: BASE + k.slug + SUFFIX,\n  }\n}));"
                                     }
