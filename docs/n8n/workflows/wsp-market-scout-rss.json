                      "parameters":  {
                                         "mode":  "runOnceForAllItems",
                                         "jsCode":  "function stripTags(raw) {\n  let t = \u0027\u0027;\n  let inTag = false;\n  for (let i = 0; i \u003c raw.length; i++) {\n    if (raw[i] === \u0027\u003c\u0027) { inTag = true; continue; }\n    if (raw[i] === \u0027\u003e\u0027) { inTag = false; continue; }\n    if (!inTag) t += raw[i];\n  }\n  return t.replace(/\\s+/g, \u0027 \u0027).trim();\n}\n\nfunction extractTitle(html, hrefIdx, relUrl) {\n  const ctx = html.substring(hrefIdx, Math.min(html.length, hrefIdx + 3000));\n  // Zweites Vorkommen der URL = Titel-Link\n  const second = ctx.indexOf(\u0027href=\"\u0027 + relUrl + \u0027\"\u0027, 10);\n  if (second !== -1) {\n    const gt = ctx.indexOf(\u0027\u003e\u0027, second);\n    const ca = ctx.indexOf(\u0027\u003c/a\u003e\u0027, second);\n    if (gt !== -1 \u0026\u0026 ca !== -1 \u0026\u0026 ca \u003e gt \u0026\u0026 ca - gt \u003c 400) {\n      const t = stripTags(ctx.substring(gt + 1, ca));\n      if (t.length \u003e 3 \u0026\u0026 t.length \u003c 300) return t;\n    }\n  }\n  for (const tag of [\u0027h2\u0027, \u0027h3\u0027]) {\n    const hIdx = ctx.indexOf(\u0027\u003c\u0027 + tag);\n    if (hIdx !== -1 \u0026\u0026 hIdx \u003c 2000) {\n      const gt = ctx.indexOf(\u0027\u003e\u0027, hIdx);\n      const close = ctx.indexOf(\u0027\u003c/\u0027 + tag + \u0027\u003e\u0027, hIdx);\n      if (gt !== -1 \u0026\u0026 close !== -1 \u0026\u0026 close - gt \u003c 400) {\n        const t = stripTags(ctx.substring(gt + 1, close));\n        if (t.length \u003e 3 \u0026\u0026 t.length \u003c 300) return t;\n      }\n    }\n  }\n  const gt = html.indexOf(\u0027\u003e\u0027, hrefIdx);\n  const ca = html.indexOf(\u0027\u003c/a\u003e\u0027, hrefIdx);\n  if (gt !== -1 \u0026\u0026 ca !== -1 \u0026\u0026 ca - gt \u003c 400) {\n    const t = stripTags(html.substring(gt + 1, ca));\n    if (t.length \u003e 3 \u0026\u0026 t.length \u003c 300) return t;\n  }\n  return null;\n}\n\nfunction extractPrice(ctx) {\n  const euro = \u0027\\u20ac\u0027;\n  const idx = ctx.indexOf(euro);\n  if (idx === -1) return null;\n  let start = idx - 1;\n  while (start \u003e= 0) {\n    const c = ctx.charCodeAt(start);\n    if ((c \u003e= 48 \u0026\u0026 c \u003c= 57) || ctx[start] === \u0027.\u0027 || ctx[start] === \u0027,\u0027 || ctx[start] === \u0027 \u0027) {\n      start--;\n    } else break;\n  }\n  let price = ctx.substring(start + 1, idx + 1).trim();\n  const after = ctx.substring(idx + 1, idx + 5).trim();\n  if (after.indexOf(\u0027VB\u0027) === 0) price += \u0027 VB\u0027;\n  return price.length \u003e 1 \u0026\u0026 price.length \u003c 25 ? price : null;\n}\n\nfunction extractImage(ctx) {\n  const searches = [\u0027src=\"https://img.kleinanzeigen.de/\u0027, \u0027src=\"https://i.ebayimg.com/\u0027];\n  for (const s of searches) {\n    const idx = ctx.indexOf(s);\n    if (idx !== -1) {\n      const start = idx + 5;\n      const end = ctx.indexOf(\u0027\"\u0027, start);\n      if (end !== -1) return ctx.substring(start, end);\n    }\n  }\n  return null;\n}\n\nfunction extractLocation(ctx) {\n  const dateWords = [\u0027Heute\u0027, \u0027Gestern\u0027, \u0027Vorgestern\u0027];\n  for (const kw of dateWords) {\n    const idx = ctx.indexOf(kw);\n    if (idx !== -1 \u0026\u0026 idx \u003c 2500) {\n      const before = ctx.substring(Math.max(0, idx - 300), idx);\n      const lastGt = before.lastIndexOf(\u0027\u003e\u0027);\n      if (lastGt !== -1) {\n        const city = before.substring(lastGt + 1).replace(/[\\u2022\\|]/g, \u0027\u0027).trim();\n        if (city.length \u003e 2 \u0026\u0026 city.length \u003c 60) return city;\n      }\n    }\n  }\n  return null;\n}\n\nfunction parseKleinanzeigenHtml(html) {\n  const listings = [];\n  const seen = new Set();\n  const hrefSearch = \u0027href=\"/s-anzeige/\u0027;\n  let pos = 0;\n\n  while (pos \u003c html.length \u0026\u0026 listings.length \u003c 25) {\n    const hrefIdx = html.indexOf(hrefSearch, pos);\n    if (hrefIdx === -1) break;\n    const urlStart = hrefIdx + 6;\n    const urlEnd = html.indexOf(\u0027\"\u0027, urlStart);\n    if (urlEnd === -1) { pos = hrefIdx + 1; continue; }\n    const relUrl = html.substring(urlStart, urlEnd);\n    pos = urlEnd + 1;\n\n    const segs = relUrl.split(\u0027/\u0027);\n    const lastSeg = segs[segs.length - 1];\n    const adId = lastSeg.split(\u0027-\u0027)[0];\n    if (adId.length \u003c 9 || adId.length \u003e 13) continue;\n    let isNum = true;\n    for (let i = 0; i \u003c adId.length; i++) {\n      const c = adId.charCodeAt(i);\n      if (c \u003c 48 || c \u003e 57) { isNum = false; break; }\n    }\n    if (!isNum || seen.has(adId)) continue;\n    seen.add(adId);\n\n    const url = \u0027https://www.kleinanzeigen.de\u0027 + relUrl;\n    let title = extractTitle(html, hrefIdx, relUrl);\n    if (!title) {\n      const slug = segs.length \u003e= 3 ? segs[segs.length - 2] : \u0027\u0027;\n      title = slug.length \u003e 3\n        ? slug.replace(/-/g, \u0027 \u0027).replace(/^./, c =\u003e c.toUpperCase())\n        : \u0027Anzeige \u0027 + adId;\n    }\n\n    const ctxEnd = Math.min(html.length, hrefIdx + 3000);\n    const ctx = html.substring(Math.max(0, hrefIdx - 200), ctxEnd);\n\n    listings.push({\n      adId, title,\n      price: extractPrice(ctx),\n      description: null,\n      location: extractLocation(ctx),\n      plz: null, date: null,\n      url,\n      image: extractImage(ctx),\n      shipping: null,\n    });\n  }\n  return listings;\n}\n\nconst keywordItems = $(\u0027Keywords laden\u0027).all();\nconst htmlItems = $input.all();\nconst results = [];\nfor (let i = 0; i \u003c htmlItems.length; i++) {\n  const kwItem = keywordItems[i];\n  const keyword = kwItem ? kwItem.json.keyword : \u0027unknown\u0027;\n  const category = kwItem ? kwItem.json.category : \u0027\u0027;\n  const html = String(htmlItems[i].json.data || htmlItems[i].json || \u0027\u0027);\n  const listings = parseKleinanzeigenHtml(html);\n  results.push({ json: { source: \u0027kleinanzeigen\u0027, keyword, category, listingCount: listings.length, listings } });\n}\nreturn results;"
                                     }
                  },
