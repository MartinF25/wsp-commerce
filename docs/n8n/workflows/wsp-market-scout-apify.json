                                   ],
                      "parameters":  {
                                         "method":  "POST",
                                         "url":  "=https://api.apify.com/v2/acts/epctex~kleinanzeigen-scraper/run-sync-get-dataset-items?token={{ $vars.APIFY_API_TOKEN }}\u0026timeout=120\u0026format=json",
                                         "authentication":  "none",
                                         "sendHeaders":  true,
                                         "headerParameters":  {
                                                                  "parameters":  [
                                                                                     {
                                                                                         "name":  "Content-Type",
                                                                                         "value":  "application/json"
                                                                                     }
                                                                                 ]
                                                              },
                                         "sendBody":  true,
                                         "specifyBody":  "json",
                                         "jsonBody":  "={{ JSON.stringify({ search: $json.keyword, maxItems: 50, country: \u0027DE\u0027 }) }}",
                                         "options":  {
                                                         "timeout":  130000
                                                     }
                                     }
                  },
                  {
                      "id":  "a1b2c3d4-0005-4005-8005-555555555555",
                      "name":  "Normalisieren + adId",
                      "type":  "n8n-nodes-base.code",
                      "typeVersion":  2,
                      "position":  [
                                       820,
                                       300
                                   ],
                      "parameters":  {
                                         "jsCode":  "const keyword = $(\u0027Keywords laden\u0027).item.json.keyword;\nconst category = $(\u0027Keywords laden\u0027).item.json.category;\n\nconst raw = $input.first().json;\nlet apifyItems = [];\n\nif (Array.isArray(raw)) {\n  apifyItems = raw;\n} else if (raw \u0026\u0026 typeof raw === \u0027object\u0027) {\n  const arrayVal = Object.values(raw).find(v =\u003e Array.isArray(v));\n  if (arrayVal) apifyItems = arrayVal;\n}\n\nconst seen = new Set();\nconst listings = [];\n\nfor (const r of apifyItems) {\n  if (!r || typeof r !== \u0027object\u0027) continue;\n\n  const url = String(r.url || r.link || r.href || r.listingUrl || \u0027\u0027).trim();\n\n  // adId aus URL extrahieren (7-12 stellige Zahl im Pfad, vor Bindestrichen)\n  let adId = null;\n  const urlPath = url.split(\u0027?\u0027)[0].split(\u0027#\u0027)[0];\n  for (const seg of urlPath.split(\u0027/\u0027)) {\n    const part = seg.split(\u0027-\u0027)[0];\n    if (part.length \u003e= 7 \u0026\u0026 part.length \u003c= 12) {\n      let isNum = true;\n      for (let i = 0; i \u003c part.length; i++) {\n        const c = part.charCodeAt(i);\n        if (c \u003c 48 || c \u003e 57) { isNum = false; break; }\n      }\n      if (isNum) { adId = part; break; }\n    }\n  }\n\n  const title = String(r.title || r.name || r.headline || \u0027\u0027).trim();\n  if (!adId || !title) continue;\n  if (seen.has(adId)) continue;\n  seen.add(adId);\n\n  const price = r.price || r.priceText || r.priceRaw || r.priceFormatted || null;\n\n  let image = null;\n  if (Array.isArray(r.images) \u0026\u0026 r.images.length \u003e 0) {\n    image = String(r.images[0]);\n  } else {\n    image = r.image || r.imageUrl || r.thumbnail || r.photo || null;\n  }\n\n  const plzRaw = r.zip || r.zipCode || r.postalCode || r.plz || null;\n\n  listings.push({\n    adId,\n    title,\n    price: price != null ? String(price).trim() : null,\n    description: r.description || r.text || r.body || null,\n    location: r.location || r.address || r.city || r.area || null,\n    plz: plzRaw != null ? String(plzRaw).trim() : null,\n    date: r.date || r.createdAt || r.listedAt || r.publishedAt || null,\n    url: url || null,\n    image: image ? String(image) : null,\n    shipping: r.shipping || r.shippingCost || null,\n  });\n}\n\nreturn [{\n  json: {\n    source: \u0027kleinanzeigen\u0027,\n    keyword,\n    category,\n    listingCount: listings.length,\n    listings,\n  }\n}];"
                                     }
                  },
