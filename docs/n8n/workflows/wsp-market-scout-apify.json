                                   ],
                      "parameters":  {
                                         "jsCode":  "// Fokus: kleine, gut versendbare Solar-Zubehoerteile\n// Apify epctex/kleinanzeigen-scraper - sucht deutschlandweit\nconst keywords = [\n  // WECHSELRICHTER – HOCH (leicht, versendbar, hohe Marge)\n  { keyword: \u0027Hoymiles Wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Deye Wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Growatt Wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Goodwe Wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Huawei SUN2000\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027SMA Wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Sungrow Hybrid Wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Fronius Hybrid Wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Solax Wechselrichter\u0027, category: \u0027wechselrichter\u0027 },\n  { keyword: \u0027Mikrowechselrichter Solar\u0027, category: \u0027wechselrichter\u0027 },\n  // LADEREGLER – HOCH (klein, leicht, gute Marge)\n  { keyword: \u0027Victron MPPT Laderegler\u0027, category: \u0027laderegler\u0027 },\n  { keyword: \u0027MPPT Laderegler Solar\u0027, category: \u0027laderegler\u0027 },\n  { keyword: \u0027EPever MPPT\u0027, category: \u0027laderegler\u0027 },\n  { keyword: \u0027Solarladeregler\u0027, category: \u0027laderegler\u0027 },\n  // OPTIMIZER – MITTEL\n  { keyword: \u0027SolarEdge Optimizer\u0027, category: \u0027optimizer\u0027 },\n  { keyword: \u0027Tigo Optimizer\u0027, category: \u0027optimizer\u0027 },\n  { keyword: \u0027Leistungsoptimierer Solar\u0027, category: \u0027optimizer\u0027 },\n  // HALTERUNGEN – MITTEL\n  { keyword: \u0027Solarmodul Halterung\u0027, category: \u0027halterung\u0027 },\n  { keyword: \u0027Solar Aufstaenderung\u0027, category: \u0027halterung\u0027 },\n  { keyword: \u0027PV Montagesystem\u0027, category: \u0027halterung\u0027 },\n  // BESTAND\n  { keyword: \u0027Solarzaun\u0027, category: \u0027solarzaun\u0027 },\n  { keyword: \u0027PV Zaun bifazial\u0027, category: \u0027solarzaun\u0027 },\n  { keyword: \u0027Pylontech Speicher\u0027, category: \u0027solarspeicher\u0027 },\n  { keyword: \u0027Victron Speicher\u0027, category: \u0027solarspeicher\u0027 },\n];\n\nreturn keywords.map(k =\u003e ({ json: k }));"
                                     }
                  },
                  {
                      "id":  "a1b2c3d4-0004-4004-8004-444444444444",
                      "name":  "Apify â€“ Kleinanzeigen scrapen",
                      "type":  "n8n-nodes-base.httpRequest",
                      "typeVersion":  4.2,
                      "position":  [
                                       580,
