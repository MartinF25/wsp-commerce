# =============================================================================
# wsp-commerce — Environment Variables
# Copy this file to .env and fill in all values before running locally.
# Never commit .env — it is in .gitignore.
# =============================================================================


# ── App ───────────────────────────────────────────────────────────────────────
# Public base URL of the Next.js storefront (used for canonical URLs, OG tags)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Internal URL of the Commerce API, used by the Storefront server-side
COMMERCE_API_URL=http://localhost:4000


# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Local: matches docker-compose.yml defaults (postgres/postgres)
# Production: use a managed connection string (Railway, Supabase, Neon, etc.)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wsp_commerce


# ── Firebase — Admin / Server-side ───────────────────────────────────────────
# Used by: apps/commerce (JWT verification), apps/firebase (Functions)
# Find these in: Firebase Console → Project Settings → General / Service Accounts

FIREBASE_PROJECT_ID=your-firebase-project-id

# Full JSON blob of the service account key (single line, JSON-stringified).
# Alternative: set GOOGLE_APPLICATION_CREDENTIALS to an absolute path instead.
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Storage bucket name — typically <project-id>.appspot.com or <project-id>.firebasestorage.app
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com


# ── Firebase — Client / Storefront (browser-safe) ────────────────────────────
# Used by: apps/storefront (Firebase Auth, Storage uploads)
# Find these in: Firebase Console → Project Settings → Your Apps → Web App → SDK config

NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-firebase-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abc123


# ── n8n ───────────────────────────────────────────────────────────────────────
# Base URL of your n8n instance (local: http://localhost:5678)
N8N_WEBHOOK_URL=http://localhost:5678

# Secret shared between Firebase Functions and n8n to authenticate webhook calls.
# Set the same value in the n8n workflow Header Auth credential.
N8N_WEBHOOK_SECRET=changeme-local

# Encryption key for persisting n8n credentials across container restarts.
# Minimum 32 characters. Generate locally with: openssl rand -hex 32
# Must match the value configured in docker-compose (if set there).
N8N_ENCRYPTION_KEY=changeme-local-replace-with-32-char-random-string


# ── Stripe ────────────────────────────────────────────────────────────────────
# Used by: apps/commerce (payment intents, webhook verification)
# Used by: apps/storefront (Stripe.js initialization — public key only)
# Test keys: https://dashboard.stripe.com/test/apikeys

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...


# ── Resend (E-Mail) ───────────────────────────────────────────────────────────
# Used by: apps/commerce (Widerruf-Bestätigungsmails, Lead-Fallback)
# Get your API key at: https://resend.com/api-keys
RESEND_API_KEY=re_...

# Verified "From"-E-Mail-Adresse in Resend (muss zur verifizierten Domain passen)
# Fallback: onboarding@resend.dev (nur für Tests ohne eigene Domain)
RESEND_FROM_EMAIL=noreply@wsp-solarenergie.de

# Standard-Empfänger für Lead- und Widerruf-Benachrichtigungen
LEAD_TO_EMAIL=verkauf@wsp-solarenergie.de


# ── Admin ─────────────────────────────────────────────────────────────────────
# Authentifizierungsschlüssel für die Commerce Admin API (X-Admin-Key Header)
ADMIN_SECRET=changeme-strong-admin-secret

# Wird im Admin-App verwendet, um die Commerce Admin API zu erreichen
ADMIN_API_KEY=changeme-strong-admin-secret

# Öffentliche URL des Admin-Panels (für Links in Admin-E-Mails)
ADMIN_URL=http://localhost:3002


# ── Widerruf-Feature (Datenschutz) ───────────────────────────────────────────
# Optionaler Salt für den SHA-256-Hash der Kunden-IP (DSGVO-konformes Logging)
# Generieren mit: openssl rand -hex 16
IP_HASH_SALT=changeme-replace-with-random-32-chars


# =============================================================================
# Not included here (added in later phases):
# - CRM credentials (HubSpot, Pipedrive) → configured inside n8n workflows
# - Redis connection → not in current stack (Phase 6+ if needed for cart)
# =============================================================================
