// Prisma Schema – wsp-commerce / Commerce Core
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

/// Steuert Kauf- vs. Anfragelogik an der Domain-Grenze.
/// direct_purchase    → Warenkorb + Checkout möglich
/// configurable       → Variantenauswahl, dann Warenkorb
/// inquiry_only       → kein Warenkorb, nur Lead-Formular
/// affiliate_external → kein eigener Checkout, externer Partnerlink (z. B. Amazon)
enum ProductType {
  direct_purchase
  configurable
  inquiry_only
  affiliate_external
}

enum ProductStatus {
  draft
  active
  archived
}

enum BlogStatus {
  draft
  published
  archived
}

/// Unterstützte Inhaltssprachen. DE ist Pflicht (Source of Truth).
/// Fehlende Übersetzungen fallen auf DE zurück (Service-Layer).
enum Locale {
  de
  en
  es
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Category {
  id               String  @id @default(uuid())
  slug             String  @unique
  name             String
  description      String?
  image_url        String?
  meta_title       String?
  meta_description String?
  is_active        Boolean @default(true)
  parent_id        String?

  parent       Category?             @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children     Category[]            @relation("CategoryHierarchy")
  products     Product[]
  translations CategoryTranslation[]

  @@map("categories")
}

/// Sprachabhängige Texte einer Produktkategorie. DE ist immer Pflicht.
/// Fehlende EN/ES-Einträge → Fallback auf DE im Service-Layer.
model CategoryTranslation {
  id               String @id @default(uuid())
  category_id      String
  locale           Locale

  name             String
  description      String?
  meta_title       String?
  meta_description String?

  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([category_id, locale])
  @@map("category_translations")
}

model Product {
  id           String        @id @default(uuid())
  slug         String        @unique
  product_type ProductType   @default(inquiry_only)
  status       ProductStatus @default(draft)
  category_id  String?
  /// PayPal Payment Link (z.B. https://www.paypal.com/paypalme/... oder https://www.paypal.com/checkout/...)
  paypal_url   String?
  /// Stripe Payment Link (z.B. https://buy.stripe.com/...)
  stripe_url   String?

  /// Angebotszeitraum. Null = sofort aktiv / kein Ablauf.
  sale_starts_at   DateTime?
  sale_ends_at     DateTime?
  /// Optionales Label, z.B. "Frühjahrsangebot". Null = Default "Angebot".
  sale_label       String?
  /// Countdown nur anzeigen wenn sale_ends_at gesetzt ist.
  show_countdown   Boolean   @default(false)

  /// Affiliate-Konfiguration – nur relevant wenn product_type = affiliate_external.
  /// affiliate_url muss den korrekten Partner-Tag des Anbieters enthalten.
  /// Kein eigener Checkout, kein Warenkorb für Produkte dieses Typs.
  affiliate_provider     String?
  affiliate_url          String?
  affiliate_asin         String?
  affiliate_button_label String?
  affiliate_disclosure   String?
  affiliate_enabled      Boolean @default(false)

  category         Category?            @relation(fields: [category_id], references: [id])
  translations     ProductTranslation[]
  variants         ProductVariant[]
  images           ProductImage[]
  documents        ProductDocument[]
  affiliate_clicks AffiliateClick[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("products")
}

/// Datensparsames Klick-Event für Affiliate-Statistiken.
/// Kein Bezug zu Nutzerprofilen – keine IP, kein User-Agent, keine personenbezogenen Daten.
model AffiliateClick {
  id            String   @id @default(uuid())
  product_id    String
  clicked_at    DateTime @default(now())
  /// Pfad der Quellseite (z. B. "/de/products/solar-panel-x200")
  referrer_path String?
  /// Sprachversion der Seite zum Zeitpunkt des Klicks
  locale        String?

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([clicked_at])
  @@map("affiliate_clicks")
}

/// Sprachabhängige Texte eines Produkts. DE ist immer Pflicht.
/// Fehlende EN/ES-Einträge → Fallback auf DE im Service-Layer.
model ProductTranslation {
  id                String @id @default(uuid())
  product_id        String
  locale            Locale

  name              String
  short_description String?
  description       String?
  delivery_note     String?
  /// Redaktionelle Bullet Points für Produktdetailseiten.
  features          Json   @default("[]")
  meta_title        String?
  meta_description  String?
  mounting_note     String?
  project_note      String?

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, locale])
  @@map("product_translations")
}

model ProductVariant {
  id             String  @id @default(uuid())
  product_id     String
  sku            String  @unique
  is_active      Boolean @default(true)
  /// Preis in Cent (integer). Null erlaubt bei inquiry_only ohne Richtpreis.
  price_cents      Int?
  /// Sale-Preis in Cent. Null = kein Angebot auf dieser Variante.
  sale_price_cents Int?
  currency       String  @default("EUR")
  stock_quantity Int     @default(0)
  /// Flexible Produkt-Attribute (Farbe, Länge, Leistung …) als JSONB.
  attributes     Json    @default("{}")
  weight_kg      Float?
  dimensions     Json?

  product      Product                    @relation(fields: [product_id], references: [id], onDelete: Cascade)
  translations ProductVariantTranslation[]

  created_at DateTime @default(now())

  @@map("product_variants")
}

/// Sprachabhängiger Name einer Produktvariante.
model ProductVariantTranslation {
  id         String @id @default(uuid())
  variant_id String
  locale     Locale
  name       String

  variant ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@unique([variant_id, locale])
  @@map("product_variant_translations")
}

model ProductImage {
  id         String  @id @default(uuid())
  product_id String
  url        String
  alt        String?
  sort_order Int     @default(0)

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductDocument {
  id         String @id @default(uuid())
  product_id String
  name       String
  url        String
  /// datasheet | manual | certificate | other
  type       String @default("datasheet")
  sort_order Int    @default(0)

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_documents")
}

model BlogCategory {
  id         String  @id @default(uuid())
  slug       String  @unique
  sort_order Int     @default(0)
  is_active  Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  translations BlogCategoryTranslation[]
  posts        BlogPost[]

  @@map("blog_categories")
}

/// Sprachabhängiger Name und Beschreibung einer Blog-Kategorie.
model BlogCategoryTranslation {
  id          String @id @default(uuid())
  category_id String
  locale      Locale
  name        String
  description String?

  category BlogCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([category_id, locale])
  @@map("blog_category_translations")
}

model BlogPost {
  id                   String     @id @default(uuid())
  slug                 String     @unique
  status               BlogStatus @default(draft)
  cover_image_url      String?
  /// Sprachneutraler Alt-Text (Bildtitel), gilt für alle Sprachversionen.
  cover_image_alt      String?
  published_at         DateTime?
  reading_time_minutes Int?
  featured             Boolean    @default(false)
  category_id          String?
  /// Einfaches Autorfeld ohne separates Author-Modell (MVP).
  author_name          String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  category     BlogCategory?        @relation(fields: [category_id], references: [id])
  translations BlogPostTranslation[]
  tags         BlogPostTag[]

  @@map("blog_posts")
}

/// Sprachabhängige Inhalte eines Blogbeitrags. DE ist immer Pflicht.
/// Fehlende EN/ES-Einträge → Fallback auf DE im Service-Layer (fallbackUsed: true).
model BlogPostTranslation {
  id               String @id @default(uuid())
  post_id          String
  locale           Locale

  title            String
  excerpt          String
  content          String  @db.Text
  meta_title       String?
  meta_description String?
  og_title         String?
  og_description   String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  post BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([post_id, locale])
  @@map("blog_post_translations")
}

model BlogTag {
  id   String @id @default(uuid())
  slug String @unique
  /// DE-Name reicht für Tags; kein eigenes Translation-Modell nötig.
  name String

  posts BlogPostTag[]

  @@map("blog_tags")
}

/// Verbindungstabelle BlogPost ↔ BlogTag (n:m).
model BlogPostTag {
  post_id String
  tag_id  String

  post BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([post_id, tag_id])
  @@map("blog_post_tags")
}
