// Prisma Schema – wsp-commerce / Commerce Core
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

/// Steuert Kauf- vs. Anfragelogik an der Domain-Grenze.
/// direct_purchase    → Warenkorb + Checkout möglich
/// configurable       → Variantenauswahl, dann Warenkorb
/// inquiry_only       → kein Warenkorb, nur Lead-Formular
/// affiliate_external → kein eigener Checkout, externer Partnerlink (z. B. Amazon)
enum ProductType {
  direct_purchase
  configurable
  inquiry_only
  affiliate_external
}

enum ProductStatus {
  draft
  active
  archived
}

/// Steuert die Verfügbarkeitsanzeige und Wartelisten-CTA im Storefront.
/// in_stock       → normal kaufbar / anfragbar
/// out_of_stock   → nicht verfügbar, Wartelisten-CTA anzeigen
/// preorder       → Vorbestellung möglich (zukünftige Phase)
/// discontinued   → eingestellt, kein Waitlist-CTA
/// on_request     → immer auf Anfrage (überschreibt stock_quantity)
enum AvailabilityStatus {
  in_stock
  out_of_stock
  preorder
  discontinued
  on_request
}

enum BlogStatus {
  draft
  published
  archived
}

// ─── Bundle Enums ─────────────────────────────────────────────────────────────

/// active   → Bundle wird im Storefront angezeigt
/// inactive → Bundle ist deaktiviert (kein Anzeigen)
enum BundleStatus {
  active
  inactive
}

/// none        → Nur Cross-Sell-Anzeige, kein Rabatt
/// percentage  → Prozentualer Rabatt auf den Bundle-Gesamtpreis
/// fixed       → Fester Rabattbetrag in Cent
/// per_item    → Individueller Rabatt pro Bundle-Produkt
enum BundleDiscountType {
  none
  percentage
  fixed
  per_item
}

/// all_items  → Rabatt gilt nur wenn alle Pflichtprodukte im Warenkorb sind
/// min_count  → Rabatt gilt ab min_items_for_discount ausgewählten Produkten
/// any_item   → Rabatt gilt bei jedem Bundle-Kauf (mind. 1 Produkt)
enum BundleDiscountMode {
  all_items
  min_count
  any_item
}

/// card   → Kartenlayout (Standard)
/// list   → Kompaktes Listenlayout
/// slider → Slider/Karussell
/// tabs   → Tab-Darstellung für mehrere Bundle-Gruppen
enum BundleDisplayMode {
  card
  list
  slider
  tabs
}

/// Unterstützte Inhaltssprachen. DE ist Pflicht (Source of Truth).
/// Fehlende Übersetzungen fallen auf DE zurück (Service-Layer).
enum Locale {
  de
  en
  es
}

// ─── Sticker / Label Enums ────────────────────────────────────────────────────

enum StickerStatus {
  active
  inactive
}

/// image     → Nur Bild-Overlay
/// text      → Nur Text-Label (CSS-gestaltet)
/// css_badge → Tailwind/CSS-Badge
/// tooltip   → Label mit Hover/Tap-Tooltip
/// combined  → Bild + Text kombiniert
enum StickerType {
  image
  text
  css_badge
  tooltip
  combined
}

/// Standardpositionen. custom erlaubt freie X/Y-Platzierung.
enum StickerPosition {
  top_left
  top_right
  bottom_left
  bottom_right
  center
  custom
}

/// Regeltypen für automatische Produkt-Zuweisung.
/// Mehrere Regeln desselben Stickers werden OR-verknüpft.
enum StickerRuleType {
  all_products
  category
  price_range
  availability
  new_arrival
}

enum DealRecommendation {
  IMPORT
  REVIEW
  IGNORE
}

enum DealRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum MarketProductCategory {
  solarzaun
  solarspeicher
  solaranlage
  skywind
  wechselrichter
  laderegler
  optimizer
  halterung
  unknown
}

enum MarketSourceStatus {
  online
  offline
  unknown
}

enum MarketSyncStatus {
  ok
  needs_review
  offline
  price_changed
}

enum MarketOpportunityStatus {
  pending
  prepared
  rejected
}

// ─── Models ──────────────────────────────────────────────────────────────────

model MarketReferencePrice {
  id          String   @id @default(uuid())
  keyword     String
  productName String
  ek_eur      Int?
  vk_eur      Int
  notes       String?  @db.Text
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([keyword])
  @@map("market_reference_prices")
}

model Category {
  id               String  @id @default(uuid())
  slug             String  @unique
  name             String
  description      String?
  image_url        String?
  meta_title       String?
  meta_description String?
  is_active        Boolean @default(true)
  parent_id        String?

  parent          Category?             @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children        Category[]            @relation("CategoryHierarchy")
  products        Product[]
  translations    CategoryTranslation[]
  ticker_messages LiveTickerMessage[]
  bundle_assignments BundleCategoryAssignment[]
  feature_definitions FeatureDefinition[]
  feature_visuals     FeatureVisual[]

  @@map("categories")
}

/// Sprachabhängige Texte einer Produktkategorie. DE ist immer Pflicht.
/// Fehlende EN/ES-Einträge → Fallback auf DE im Service-Layer.
model CategoryTranslation {
  id               String @id @default(uuid())
  category_id      String
  locale           Locale

  name             String
  description      String?
  meta_title       String?
  meta_description String?

  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([category_id, locale])
  @@map("category_translations")
}

model Product {
  id                  String             @id @default(uuid())
  slug                String             @unique
  product_type        ProductType        @default(inquiry_only)
  status              ProductStatus      @default(draft)
  availability_status AvailabilityStatus @default(in_stock)
  category_id         String?
  /// PayPal Payment Link (z.B. https://www.paypal.com/paypalme/... oder https://www.paypal.com/checkout/...)
  paypal_url   String?
  /// Stripe Payment Link (z.B. https://buy.stripe.com/...)
  stripe_url   String?

  /// Angebotszeitraum. Null = sofort aktiv / kein Ablauf.
  sale_starts_at   DateTime?
  sale_ends_at     DateTime?
  /// Optionales Label, z.B. "Frühjahrsangebot". Null = Default "Angebot".
  sale_label       String?
  /// Countdown nur anzeigen wenn sale_ends_at gesetzt ist.
  show_countdown   Boolean   @default(false)

  /// Affiliate-Konfiguration – nur relevant wenn product_type = affiliate_external.
  /// affiliate_url muss den korrekten Partner-Tag des Anbieters enthalten.
  /// Kein eigener Checkout, kein Warenkorb für Produkte dieses Typs.
  affiliate_provider     String?
  affiliate_url          String?
  affiliate_asin         String?
  affiliate_button_label String?
  affiliate_disclosure   String?
  affiliate_enabled      Boolean @default(false)

  /// Letzter automatischer Health-Check via n8n.
  affiliate_last_checked_at DateTime?
  /// Ergebnis: ok | invalid_url | missing | timeout | blocked | error
  affiliate_health_status   String?
  /// Optionale Fehlermeldung oder Hinweis vom letzten Check.
  affiliate_health_message  String?

  category         Category?            @relation(fields: [category_id], references: [id])
  translations     ProductTranslation[]
  variants         ProductVariant[]
  images           ProductImage[]
  documents        ProductDocument[]
  affiliate_clicks AffiliateClick[]
  ticker_messages  LiveTickerMessage[]
  bundle_items     BundleItem[]
  bundle_assignments BundleProductAssignment[]
  sticker_overrides  StickerProductOverride[]
  feature_visuals    FeatureVisual[]

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("products")
}

/// Datensparsames Klick-Event für Affiliate-Statistiken.
/// Kein Bezug zu Nutzerprofilen – keine IP, kein User-Agent, keine personenbezogenen Daten.
model AffiliateClick {
  id            String   @id @default(uuid())
  product_id    String
  clicked_at    DateTime @default(now())
  /// Pfad der Quellseite (z. B. "/de/products/solar-panel-x200")
  referrer_path String?
  /// Sprachversion der Seite zum Zeitpunkt des Klicks
  locale        String?
  /// Klickquelle: product_card | product_detail | solution_page | blog | unknown
  source        String?
  /// Affiliate-Anbieter, z. B. "amazon" – für spätere Multi-Provider-Auswertung
  affiliate_provider String?
  /// Gerätekategorie (aggregiert, kein Raw-User-Agent): mobile | desktop | tablet
  device_category String?

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@index([clicked_at])
  @@index([source])
  @@map("affiliate_clicks")
}

/// Sprachabhängige Texte eines Produkts. DE ist immer Pflicht.
/// Fehlende EN/ES-Einträge → Fallback auf DE im Service-Layer.
model ProductTranslation {
  id                String @id @default(uuid())
  product_id        String
  locale            Locale

  name              String
  short_description String?
  description       String?
  delivery_note     String?
  /// Redaktionelle Bullet Points für Produktdetailseiten.
  features          Json   @default("[]")
  meta_title        String?
  meta_description  String?
  mounting_note     String?
  project_note      String?

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([product_id, locale])
  @@map("product_translations")
}

model ProductVariant {
  id             String  @id @default(uuid())
  product_id     String
  sku            String  @unique
  is_active      Boolean @default(true)
  /// Preis in Cent (integer). Null erlaubt bei inquiry_only ohne Richtpreis.
  price_cents      Int?
  /// Sale-Preis in Cent. Null = kein Angebot auf dieser Variante.
  sale_price_cents Int?
  currency       String  @default("EUR")
  stock_quantity Int     @default(0)
  /// Flexible Produkt-Attribute (Farbe, Länge, Leistung …) als JSONB.
  attributes     Json    @default("{}")
  weight_kg      Float?
  dimensions     Json?

  product      Product                    @relation(fields: [product_id], references: [id], onDelete: Cascade)
  translations ProductVariantTranslation[]

  created_at DateTime @default(now())

  @@map("product_variants")
}

/// Sprachabhängiger Name einer Produktvariante.
model ProductVariantTranslation {
  id         String @id @default(uuid())
  variant_id String
  locale     Locale
  name       String

  variant ProductVariant @relation(fields: [variant_id], references: [id], onDelete: Cascade)

  @@unique([variant_id, locale])
  @@map("product_variant_translations")
}

model ProductImage {
  id         String  @id @default(uuid())
  product_id String
  url        String
  alt        String?
  sort_order Int     @default(0)

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_images")
}

model ProductDocument {
  id         String @id @default(uuid())
  product_id String
  name       String
  url        String
  /// datasheet | manual | certificate | other
  type       String @default("datasheet")
  sort_order Int    @default(0)

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@map("product_documents")
}

model BlogCategory {
  id         String  @id @default(uuid())
  slug       String  @unique
  sort_order Int     @default(0)
  is_active  Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  translations BlogCategoryTranslation[]
  posts        BlogPost[]

  @@map("blog_categories")
}

/// Sprachabhängiger Name und Beschreibung einer Blog-Kategorie.
model BlogCategoryTranslation {
  id          String @id @default(uuid())
  category_id String
  locale      Locale
  name        String
  description String?

  category BlogCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@unique([category_id, locale])
  @@map("blog_category_translations")
}

model BlogPost {
  id                   String     @id @default(uuid())
  slug                 String     @unique
  status               BlogStatus @default(draft)
  cover_image_url      String?
  /// Sprachneutraler Alt-Text (Bildtitel), gilt für alle Sprachversionen.
  cover_image_alt      String?
  published_at         DateTime?
  reading_time_minutes Int?
  featured             Boolean    @default(false)
  category_id          String?
  /// Einfaches Autorfeld ohne separates Author-Modell (MVP).
  author_name          String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  category     BlogCategory?        @relation(fields: [category_id], references: [id])
  translations BlogPostTranslation[]
  tags         BlogPostTag[]

  @@map("blog_posts")
}

/// Sprachabhängige Inhalte eines Blogbeitrags. DE ist immer Pflicht.
/// Fehlende EN/ES-Einträge → Fallback auf DE im Service-Layer (fallbackUsed: true).
model BlogPostTranslation {
  id               String @id @default(uuid())
  post_id          String
  locale           Locale

  title            String
  excerpt          String
  content          String  @db.Text
  meta_title       String?
  meta_description String?
  og_title         String?
  og_description   String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  post BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([post_id, locale])
  @@map("blog_post_translations")
}

model BlogTag {
  id   String @id @default(uuid())
  slug String @unique
  /// DE-Name reicht für Tags; kein eigenes Translation-Modell nötig.
  name String

  posts BlogPostTag[]

  @@map("blog_tags")
}

/// Verbindungstabelle BlogPost ↔ BlogTag (n:m).
model BlogPostTag {
  post_id String
  tag_id  String

  post BlogPost @relation(fields: [post_id], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([post_id, tag_id])
  @@map("blog_post_tags")
}

// ─── Live-Ticker ──────────────────────────────────────────────────────────────

enum LiveTickerStatus {
  draft
  active
  archived
}

/// info        → allgemeiner Hinweis (neutral)
/// offer       → echtes, datenbankgestütztes Angebot mit Zeitraum
/// availability → Verfügbarkeitsstatus (wieder da, auf Anfrage …)
/// blog        → Verweis auf neuen Ratgeber / Blog-Post
/// product     → produktbezogener Hinweis
/// warning     → wichtiger Systemhinweis
enum LiveTickerType {
  info
  offer
  availability
  blog
  product
  warning
}

/// global   → alle Seiten (unter dem Header)
/// product  → nur auf /products/[slug] (product_id muss gesetzt sein)
/// category → nur auf /categories/[slug] (category_id muss gesetzt sein)
/// solution → nur auf Lösungsseiten (solution_slug: "solarzaun" | "skywind" | "kombiloesungen")
enum LiveTickerScope {
  global
  product
  category
  solution
}

/// Admin-verwaltete Ticker-Nachrichten.
/// DE-Übersetzung ist Pflicht; EN/ES fallen auf DE zurück (Service-Layer).
/// starts_at / ends_at steuern den Aktivierungszeitraum (null = sofort / kein Ablauf).
model LiveTickerMessage {
  id            String           @id @default(uuid())
  status        LiveTickerStatus @default(draft)
  type          LiveTickerType
  scope         LiveTickerScope  @default(global)
  product_id    String?
  category_id   String?
  solution_slug String?
  priority      Int              @default(0)
  starts_at     DateTime?
  ends_at       DateTime?
  link_href     String?
  icon          String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  product      Product?                       @relation(fields: [product_id], references: [id], onDelete: SetNull)
  category     Category?                      @relation(fields: [category_id], references: [id], onDelete: SetNull)
  translations LiveTickerMessageTranslation[]

  @@index([status, scope])
  @@index([starts_at, ends_at])
  @@map("live_ticker_messages")
}

/// Sprachabhängiger Text einer Ticker-Nachricht. DE ist immer Pflicht.
/// Fehlende EN/ES-Einträge → Fallback auf DE im Service-Layer.
model LiveTickerMessageTranslation {
  id         String @id @default(uuid())
  message_id String
  locale     Locale

  text       String
  link_label String?

  message LiveTickerMessage @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@unique([message_id, locale])
  @@map("live_ticker_message_translations")
}

// ─── Cross-Sell Bundles ───────────────────────────────────────────────────────

/// Admin-verwaltetes Produkt-Bundle: Gruppe von Produkten mit Cross-Sell-Anzeige
/// und optionalem Rabatt. Bundles werden Produkten oder Kategorien zugewiesen.
/// DE-Übersetzung ist Pflicht; EN/ES fallen auf DE zurück (Service-Layer).
model Bundle {
  id          String        @id @default(uuid())
  status      BundleStatus  @default(inactive)
  sort_order  Int           @default(0)
  image_url   String?
  valid_from  DateTime?
  valid_until DateTime?
  /// Multi-Store-Vorbereitung: null = alle Stores
  store_id    String?

  // ─── Rabattlogik ─────────────────────────────────────────────────────────
  discount_type          BundleDiscountType @default(none)
  /// Prozentualer Rabatt, z.B. 10.00 für 10%. Nur relevant wenn discount_type=percentage.
  discount_percent       Decimal?           @db.Decimal(5, 2)
  /// Fester Rabatt in Cent. Nur relevant wenn discount_type=fixed.
  discount_cents         Int?
  discount_mode          BundleDiscountMode @default(all_items)
  /// Mindestanzahl ausgewählter Produkte für Rabatt (discount_mode=min_count).
  min_items_for_discount Int                @default(1)
  /// Zeitlich begrenzter Rabatt – unabhängig von Bundle-Gültigkeit.
  valid_from_discount    DateTime?
  valid_until_discount   DateTime?

  // ─── Darstellung ─────────────────────────────────────────────────────────
  display_mode BundleDisplayMode @default(card)
  /// Optionaler Gruppenname für Tab-Darstellung, z.B. "zubehoer", "starter-set".
  tab_group    String?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  translations         BundleTranslation[]
  items                BundleItem[]
  product_assignments  BundleProductAssignment[]
  category_assignments BundleCategoryAssignment[]

  @@index([status, sort_order])
  @@index([valid_from, valid_until])
  @@map("bundles")
}

/// Sprachabhängige Texte eines Bundles. DE ist immer Pflicht.
/// Fehlende EN/ES-Einträge → Fallback auf DE im Service-Layer.
model BundleTranslation {
  id          String @id @default(uuid())
  bundle_id   String
  locale      Locale

  title       String
  description String?
  /// Label für Tab-Darstellung (z.B. "Zubehör", "Häufig zusammen gekauft").
  tab_name    String?

  bundle Bundle @relation(fields: [bundle_id], references: [id], onDelete: Cascade)

  @@unique([bundle_id, locale])
  @@map("bundle_translations")
}

/// Ein Produkt innerhalb eines Bundles. Jede Kombination bundle+product ist unique.
/// discount_percent / discount_cents überschreiben den Bundle-Level-Rabatt für dieses Produkt.
model BundleItem {
  id               String   @id @default(uuid())
  bundle_id        String
  product_id       String
  quantity         Int      @default(1)
  /// true = Pflichtprodukt (muss ausgewählt bleiben); false = optional (Checkbox)
  is_required      Boolean  @default(true)
  sort_order       Int      @default(0)
  /// Individueller Produkt-Rabatt in Prozent (überschreibt Bundle-Rabatt).
  discount_percent Decimal? @db.Decimal(5, 2)
  /// Individueller Produkt-Rabatt als fester Betrag in Cent.
  discount_cents   Int?

  bundle  Bundle  @relation(fields: [bundle_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([bundle_id, product_id])
  @@map("bundle_items")
}

/// Weist ein Bundle einem oder mehreren spezifischen Produkten zu.
/// Das Bundle erscheint auf der Produktdetailseite dieser Produkte.
model BundleProductAssignment {
  bundle_id  String
  product_id String

  bundle  Bundle  @relation(fields: [bundle_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@id([bundle_id, product_id])
  @@map("bundle_product_assignments")
}

/// Weist ein Bundle einer Kategorie zu.
/// Das Bundle erscheint für alle Produkte dieser Kategorie.
model BundleCategoryAssignment {
  bundle_id   String
  category_id String

  bundle   Bundle   @relation(fields: [bundle_id], references: [id], onDelete: Cascade)
  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([bundle_id, category_id])
  @@map("bundle_category_assignments")
}

// ─── Product Stickers & Labels ────────────────────────────────────────────────

/// Admin-verwaltete Produkt-Sticker / Labels.
/// Werden automatisch via Regeln (StickerRule) oder manuell (StickerProductOverride) zugewiesen.
/// DE-Übersetzung ist Pflicht; EN/ES fallen auf DE zurück (Service-Layer).
model Sticker {
  id           String          @id @default(uuid())
  /// Interner Admin-Name (nicht im Storefront sichtbar).
  name         String
  status       StickerStatus   @default(inactive)
  /// Höherer Wert = höhere Priorität bei Konflikten.
  priority     Int             @default(0)
  sort_order   Int             @default(0)
  type         StickerType     @default(text)

  /// URL des Bild-Stickers (nur relevant wenn type=image|combined).
  image_url    String?

  /// Text-Sticker Styling – alle Felder optional, Fallback auf Defaults im Frontend.
  text_color   String?         // z. B. "#FFFFFF"
  bg_color     String?         // z. B. "#22C55E"
  border_color String?         // z. B. "#16A34A"
  font_size    String?         // z. B. "12px"
  font_bold    Boolean         @default(false)
  font_italic  Boolean         @default(false)
  border_radius String?        // z. B. "4px" oder "9999px" (Pill-Form)
  padding      String?         // z. B. "4px 8px"
  /// CSS opacity 0.00–1.00
  opacity      Decimal?        @db.Decimal(3, 2)
  /// Optionale Tailwind- oder Custom-CSS-Klasse für den Sticker.
  css_class    String?
  /// Optionales freies inline-CSS (überschreibt alle anderen Stilfelder).
  custom_css   String?

  /// Klickbarer Link-URL (optional). Übersetzbar in StickerTranslation.link_url.
  link_url     String?

  /// Position des Stickers auf dem Produktbild.
  position     StickerPosition @default(top_left)
  /// Custom X-Offset in px (nur relevant wenn position=custom).
  position_x   Int?
  /// Custom Y-Offset in px (nur relevant wenn position=custom).
  position_y   Int?

  /// Sticker-Größe je Seitenkontext als JSON:
  /// { "homepage": "80px", "listing": "70px", "detail": "100px", "search": "64px" }
  size_config  Json            @default("{}")

  /// Gültigkeitszeitraum. null = sofort aktiv / kein Ablauf.
  valid_from   DateTime?
  valid_until  DateTime?

  /// Multi-Store: null = alle Stores.
  store_id     String?

  /// Sichtbare Kundengruppen als JSON-Array: ["guest","registered","b2b","vip"].
  /// null = alle Gruppen sehen den Sticker.
  customer_groups Json?

  /// Maximale Anzahl gleichzeitig sichtbarer Sticker pro Produkt (0 = unbegrenzt).
  max_per_product Int           @default(3)
  /// Darf dieser Sticker durch manuelle Produktregeln überschrieben werden?
  allow_override  Boolean       @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  translations      StickerTranslation[]
  rules             StickerRule[]
  product_overrides StickerProductOverride[]

  @@index([status, priority])
  @@index([valid_from, valid_until])
  @@map("stickers")
}

/// Sprachabhängige Texte eines Stickers. DE ist immer Pflicht.
/// Fehlende EN/ES-Einträge → Fallback auf DE im Service-Layer.
model StickerTranslation {
  id         String  @id @default(uuid())
  sticker_id String
  locale     Locale

  /// Label-Text (für type=text/combined/css_badge/tooltip).
  text               String?
  /// Tooltip-Inhalt (sichtbar bei Hover/Tap; für type=tooltip/combined).
  tooltip            String?
  /// Link-Label im Tooltip.
  tooltip_link_label String?
  /// Locale-spezifische Tooltip-Link-URL.
  tooltip_link_url   String?
  /// Locale-spezifische Sticker-Link-URL (überschreibt Sticker.link_url).
  link_url           String?

  sticker Sticker @relation(fields: [sticker_id], references: [id], onDelete: Cascade)

  @@unique([sticker_id, locale])
  @@map("sticker_translations")
}

/// Automatische Zuweisungsregel für einen Sticker.
/// Mehrere Regeln desselben Stickers werden OR-verknüpft:
/// Ein Produkt bekommt den Sticker, wenn mindestens eine Regel zutrifft.
model StickerRule {
  id         String          @id @default(uuid())
  sticker_id String
  rule_type  StickerRuleType

  /// Kategorie-ID (nur relevant wenn rule_type=category).
  category_id String?

  /// Mindestpreis in Cent (nur relevant wenn rule_type=price_range).
  price_min_cents Int?
  /// Maximalpreis in Cent (nur relevant wenn rule_type=price_range).
  price_max_cents Int?

  /// Verfügbarkeitsstatus als String (nur relevant wenn rule_type=availability).
  /// Werte: "in_stock" | "out_of_stock" | "preorder" | "discontinued" | "on_request"
  availability_status String?

  /// Produkt muss innerhalb der letzten N Tage erstellt worden sein (rule_type=new_arrival).
  new_arrival_days Int?

  sticker Sticker @relation(fields: [sticker_id], references: [id], onDelete: Cascade)

  @@map("sticker_rules")
}

// ─── Market Listings (Kleinanzeigen Marktbeobachtung) ─────────────────────────

/// Täglich via n8n von Kleinanzeigen importierte Marktangebote.
/// Dient der Preisanalyse und Marktbeobachtung im Admin-Bereich.
/// ad_id ist eindeutig → verhindert Duplikate bei täglichem Re-Import.
model MarketListing {
  id               String    @id @default(uuid())
  /// Kleinanzeigen-Anzeigen-ID (z.B. "3409646684"). Unique-Constraint verhindert Duplikate.
  ad_id            String    @unique
  source           String    @default("kleinanzeigen")
  keyword          String    @default("skywind")

  title            String
  /// Originalpreisstring, z.B. "1.500 € VB"
  price_raw        String?
  /// Preis in Cent (geparst). Null wenn nur "VB" ohne Betrag.
  price_cents      Int?
  /// true wenn Preis verhandelbar ("VB" im Preisstring enthalten)
  price_negotiable Boolean   @default(false)

  description      String?   @db.Text
  location         String?
  plz              String?

  listing_url      String?
  image_url        String?
  shipping         String?

  /// Inserate-Datum (geparst aus "Heute, 07:17" / "Gestern, HH:MM" / "DD.MM.YYYY")
  listed_at        DateTime?
  dealScore        Int?
  recommendation   DealRecommendation?
  riskLevel        DealRiskLevel?
  productCategory  MarketProductCategory?
  estimatedMargin  Int?
  seoPotential     Int?
  aiComment        String?   @db.Text
  analyzedAt       DateTime?
  productDraftId   String?
  productCreatedAt DateTime?
  productStatus    ProductStatus?

  /// Availability Agent Felder
  sourceStatus              MarketSourceStatus?
  lastAvailabilityCheckAt   DateTime?
  lastKnownPrice            Int?
  currentPrice              Int?
  priceChanged              Boolean   @default(false)
  priceChangeAmount         Int?
  availabilityNote          String?   @db.Text
  syncStatus                MarketSyncStatus?

  /// Daily Opportunity Agent Felder
  purchasePrice             Int?
  markupPercent             Int?
  suggestedSellingPrice     Int?
  estimatedGrossProfit      Int?
  pricingNote               String?   @db.Text
  opportunityStatus         MarketOpportunityStatus?
  dailyReportAt             DateTime?
  rejectedAt                DateTime?
  rejectedReason            String?   @db.Text

  /// Zeitstempel wann n8n die Daten gesammelt hat (scraped_at = jetzt beim Import)
  scraped_at       DateTime  @default(now())
  created_at       DateTime  @default(now())

  /// Knowledge Extraction Felder (Phase 4A)
  /// Normalisierte Marke, z. B. "EcoFlow", "BYD", "Pylontech"
  brand                 String?
  /// Modellbezeichnung, z. B. "STREAM AC", "US3000C"
  model                 String?
  /// Produktserie, z. B. "EcoFlow STREAM", "BYD HVS"
  productSeries         String?
  /// Produkttyp, z. B. "Solarspeicher", "Wechselrichter", "Kleinwindanlage"
  productType           String?
  /// Unterkategorie-Slug, z. B. "speicher-lifepo4", "kleinwindanlage"
  subcategory           String?
  /// Data Completeness Score 0–100 gemaess WSP-Knowledge-Intelligence Skill
  dataCompletenessScore Int?
  /// Durchschnittlicher Confidence-Wert aller Extraktionen (0.00–1.00)
  enrichmentConfidence  Float?
  /// Zeitstempel der letzten Knowledge-Extraktion
  enrichedAt            DateTime?
  /// Vollstaendiges Extraktionsergebnis mit Confidence und Source je Feld (JSONB)
  enrichmentMetadata    Json?

  @@index([scraped_at])
  @@index([source, keyword])
  @@index([price_cents])
  @@index([dealScore])
  @@index([recommendation])
  @@index([analyzedAt])
  @@index([syncStatus])
  @@index([sourceStatus])
  @@index([opportunityStatus])
  @@index([enrichedAt])
  @@index([dataCompletenessScore])
  @@index([brand])
  @@map("market_listings")
}

/// Manuelle Sticker-Zuweisung oder -Ausschluss für einzelne Produkte.
model StickerProductOverride {
  id         String  @id @default(uuid())
  sticker_id String
  product_id String

  /// false → Sticker für dieses Produkt explizit deaktiviert (auch wenn Regel greift).
  enabled  Boolean @default(true)
  /// true → Produkt vollständig vom Sticker-System ausgeschlossen (alle Sticker).
  excluded Boolean @default(false)

  sticker Sticker @relation(fields: [sticker_id], references: [id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([sticker_id, product_id])
  @@map("sticker_product_overrides")
}

// ─── Feature Visual Engine ────────────────────────────────────────────────────

/// Wie ein Feature-String erkannt wird.
/// exact    → Exaktes String-Match (case-insensitive)
/// contains → Substring-Match (Standard)
/// starts   → String beginnt mit Pattern
/// ends     → String endet mit Pattern
/// regex    → Regulärer Ausdruck
enum FeatureMatchType {
  exact
  contains
  starts
  ends
  regex
}

/// Geltungsbereich eines FeatureVisual-Eintrags.
/// global   → gilt für alle Produkte und Kategorien
/// category → nur für Produkte dieser Kategorie
/// product  → nur für dieses spezifische Produkt (höchste Priorität)
enum FeatureVisualScope {
  global
  category
  product
}

/// Darstellungsmodus der Feature-Visuals im Storefront.
/// icon_value        → Icon + Wert (kompakt)
/// icon_name_value   → Icon + Name + Wert (vollständig)
/// grouped           → gruppiert nach Feature-Name mit Abschnitt-Header
/// compact           → nur Icons, kein Text (Tooltip on Hover)
/// tooltip_only      → unsichtbar, nur Tooltip bei Hover
/// grid              → Kacheln-Layout (Icon + Label)
/// horizontal        → horizontale Scroll-Zeile
/// vertical          → vertikaler Stack (Standard)
enum FeatureDisplayMode {
  icon_value
  icon_name_value
  grouped
  compact
  tooltip_only
  grid
  horizontal
  vertical
}

/// Definiert einen Feature-Typ, z.B. "Leistung", "Schutzklasse", "Gewicht".
/// Das match_pattern bestimmt, welche Feature-Strings diesem Typ zugeordnet werden.
/// Mehrere Definitionen können auf denselben String passen – der höchste sort_order gewinnt.
model FeatureDefinition {
  id            String           @id @default(uuid())
  /// Maschinenlesbarer Bezeichner, z.B. "leistung", "schutzklasse". URL-safe.
  slug          String           @unique
  /// Mehrsprachige Anzeigenamen als JSONB, z.B. {"de":"Leistung","en":"Power"}.
  names         Json             @default("{}")
  /// Optionale Beschreibungen für Admin-UI.
  descriptions  Json?
  /// String-Pattern für automatisches Matching gegen Product.features-Strings.
  match_pattern String?
  match_type    FeatureMatchType @default(contains)
  /// Optionaler Kategorie-Scope. Null = global.
  category_id   String?
  sort_order    Int              @default(0)
  is_active     Boolean         @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  category Category?       @relation(fields: [category_id], references: [id])
  visuals  FeatureVisual[]

  @@index([slug])
  @@index([category_id])
  @@map("feature_definitions")
}

/// Visuelle Ressource für eine Feature-Definition oder einen spezifischen Feature-Wert.
/// Prioritätsregel (höchste gewinnt):
///   1. scope=product  (produktspezifische Überschreibung)
///   2. scope=category (kategorieweit)
///   3. scope=global   (überall gültig)
/// Innerhalb desselben Scope entscheidet die priority-Spalte.
model FeatureVisual {
  id                    String            @id @default(uuid())
  /// Verknüpfung zur Feature-Definition (Null = freistehende Ressource).
  feature_definition_id String?
  /// Spezifischer Featurewert, z.B. "IP65", "400 W". Null = gilt für alle Werte.
  feature_value         String?
  scope                 FeatureVisualScope @default(global)
  category_id           String?
  product_id            String?

  // ─── Assets ─────────────────────────────────────────────────────────────────
  /// CDN-URL zum Bild (PNG/JPG/GIF/WebP). Null wenn nur SVG.
  image_url    String?
  /// Inline-SVG-Inhalt (vollständiges <svg>…</svg>). Null wenn URL-Bild.
  svg_content  String?   @db.Text
  /// Bildbreite in px – für CLS-Prävention reserviert (width/height Attribute).
  image_width  Int?
  /// Bildhöhe in px – für CLS-Prävention.
  image_height Int?

  // ─── Mehrsprachige Metadaten ─────────────────────────────────────────────────
  /// Mehrsprachige Alt-Texte für Barrierefreiheit. {"de":"…","en":"…","es":"…"}
  alt_texts Json?
  /// Mehrsprachige Anzeigelabels (überschreibt Feature-Definition-Name).
  labels    Json?
  /// Mehrsprachige Tooltip-Texte.
  tooltips  Json?

  // ─── Link-Konfiguration ──────────────────────────────────────────────────────
  link_url    String?
  link_target String?  @default("_self")
  link_rel    String?

  // ─── Styling ────────────────────────────────────────────────────────────────
  color_primary   String?
  color_secondary String?
  css_class       String?

  // ─── Verwaltung ──────────────────────────────────────────────────────────────
  /// Priorität innerhalb desselben Scope (höherer Wert = bevorzugt).
  priority   Int     @default(0)
  is_active  Boolean @default(true)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  definition FeatureDefinition? @relation(fields: [feature_definition_id], references: [id], onDelete: SetNull)
  category   Category?           @relation(fields: [category_id], references: [id])
  product    Product?            @relation(fields: [product_id], references: [id])

  @@index([feature_definition_id])
  @@index([feature_value])
  @@index([scope, priority])
  @@index([category_id])
  @@index([product_id])
  @@map("feature_visuals")
}

// ─── Widerruf / EU-Cancellation ──────────────────────────────────────────────

/// Status einer Widerrufsanfrage.
enum CancellationStatus {
  widerruf_beantragt
  widerruf_in_pruefung
  widerruf_akzeptiert
  widerruf_abgelehnt
}

/// Modus der Fristprüfung (konfigurierbar im Adminbereich).
/// always_submit      → Anfrage immer annehmen, manuelle Prüfung durch Händler
/// plausibility_check → Hinweis bei möglicher Fristüberschreitung, aber immer übermitteln
/// auto_reject        → Automatische Ablehnung bei rechnerisch abgelaufener Frist
enum CancellationMode {
  always_submit
  plausibility_check
  auto_reject
}

/// Widerrufsanfrage eines Kunden.
/// Soft-Modus: order_reference wird nicht gegen eine interne Orders-Tabelle geprüft.
/// Händler prüft Bestellnummer und Berechtigung manuell.
model CancellationRequest {
  id                      String             @id @default(uuid())
  order_reference         String
  customer_email          String
  customer_first_name     String
  customer_last_name      String
  message                 String?            @db.Text
  status                  CancellationStatus @default(widerruf_beantragt)
  /// Ergebnis der Fristprüfung: "unknown" | "within" | "possible_exceeded" | "exceeded"
  deadline_check_result   String?
  excluded_items_detected Boolean            @default(false)
  /// SHA-256-Hash der Kunden-IP (DSGVO-konform, kein Klartext).
  customer_ip_hash        String?
  locale                  String             @default("de")
  admin_notes             String?            @db.Text
  customer_email_sent_at  DateTime?
  admin_email_sent_at     DateTime?
  rejection_email_sent_at DateTime?
  created_at              DateTime           @default(now())
  updated_at              DateTime           @updatedAt

  logs CancellationLog[]

  @@index([customer_email])
  @@index([order_reference])
  @@index([status])
  @@index([created_at])
  @@map("cancellation_requests")
}

/// Protokoll-Einträge zu einer Widerrufsanfrage (unveränderlich).
model CancellationLog {
  id           String              @id @default(uuid())
  request_id   String
  /// Maschinenlesbares Ereignis, z.B. "request_created", "status_changed", "email_sent".
  event        String
  details      String?
  /// "system" | "admin" | E-Mail-Adresse des handelnden Admins
  performed_by String?
  created_at   DateTime            @default(now())

  request CancellationRequest @relation(fields: [request_id], references: [id], onDelete: Cascade)

  @@index([request_id])
  @@map("cancellation_logs")
}

/// Singleton-Einstellungen für das Widerruf-Feature.
/// ID ist immer "default" – nur ein Datensatz erlaubt.
model CancellationSettings {
  id                      String           @id @default("default")
  is_active               Boolean          @default(true)
  deadline_days           Int              @default(14)
  delivery_buffer_days    Int              @default(2)
  mode                    CancellationMode @default(always_submit)
  admin_email             String           @default("")
  show_footer_link        Boolean          @default(true)
  show_account_link       Boolean          @default(true)
  privacy_page_url        String?
  cancellation_policy_url String?
  noindex                 Boolean          @default(false)
  meta_title_de           String?
  meta_title_en           String?
  meta_title_es           String?
  meta_description_de     String?
  meta_description_en     String?
  meta_description_es     String?
  updated_at              DateTime         @updatedAt

  @@map("cancellation_settings")
}

/// Produkte, die vom Widerruf ausgeschlossen sind (z.B. Maßanfertigungen).
/// Anfragen werden trotzdem übermittelt, aber mit Hinweis markiert.
model CancellationExcludedProduct {
  id           String   @id @default(uuid())
  product_id   String   @unique
  product_slug String
  product_name String
  reason       String?
  created_at   DateTime @default(now())

  @@map("cancellation_excluded_products")
}

/// Kategorien, deren Produkte vom Widerruf ausgeschlossen sind.
model CancellationExcludedCategory {
  id            String   @id @default(uuid())
  category_id   String   @unique
  category_slug String
  category_name String
  reason        String?
  created_at    DateTime @default(now())

  @@map("cancellation_excluded_categories")
}

/// Singleton-Datensatz für globale Display-Konfiguration des Feature Visual Engine.
/// ID ist immer "singleton" – nur ein Datensatz erlaubt.
model FeatureVisualSettings {
  id String @id @default("singleton")

  // ─── Anzeige-Standorte ───────────────────────────────────────────────────────
  enable_product_page   Boolean @default(true)
  enable_quick_view     Boolean @default(true)
  enable_miniature      Boolean @default(false)
  enable_faceted_search Boolean @default(true)
  enable_collection     Boolean @default(true)
  enable_search_results Boolean @default(true)

  // ─── Globale Standardwerte ───────────────────────────────────────────────────
  default_display_mode FeatureDisplayMode @default(vertical)
  default_icon_size    String             @default("md")
  show_labels          Boolean            @default(true)
  show_tooltips        Boolean            @default(true)
  enable_animations    Boolean            @default(true)

  // ─── Responsive-Konfiguration (JSONB) ────────────────────────────────────────
  /// {"desktop":{"columns":3,"gap":"md","iconSize":"md"},"tablet":{...},"mobile":{...}}
  responsive_config Json?

  // ─── Produktdetailseite ──────────────────────────────────────────────────────
  product_page_mode     FeatureDisplayMode @default(grid)
  product_page_position String             @default("below_description")
  product_page_columns  Int                @default(3)

  // ─── Produktkarte / Miniatur ─────────────────────────────────────────────────
  miniature_mode      FeatureDisplayMode @default(compact)
  miniature_max_icons Int                @default(4)
  miniature_position  String             @default("bottom")

  // ─── Faceted Search ──────────────────────────────────────────────────────────
  facet_show_icons      Boolean @default(true)
  facet_show_labels     Boolean @default(false)
  facet_collapsible     Boolean @default(true)
  facet_lazy_render     Boolean @default(true)

  // ─── Typografie ──────────────────────────────────────────────────────────────
  font_size   String @default("sm")
  font_weight String @default("medium")

  // ─── Analytics ───────────────────────────────────────────────────────────────
  track_interactions Boolean @default(false)
  enable_ab_testing  Boolean @default(false)

  updated_at DateTime @updatedAt

  @@map("feature_visual_settings")
}
