# ─── Datenbank ───────────────────────────────────────────────────────────────
# PostgreSQL-Connection-String für Prisma.
# Lokal:      docker-compose up -d → PostgreSQL auf Port 5432
# Produktion: Managed Database (z. B. Railway Postgres, Supabase)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wsp_commerce

# ─── Server ───────────────────────────────────────────────────────────────────
# Port der Commerce API.
# Default (wenn nicht gesetzt): 3001
# Auf Railway/Render wird PORT automatisch gesetzt – hier nicht nötig.
PORT=3001

# ─── CORS ────────────────────────────────────────────────────────────────────
# Erlaubte Origin für /api/*-Routen (Hono cors-Middleware).
# Lokal:      http://localhost:3000 (Next.js Storefront)
# Produktion: https://yourdomain.com
# Leer lassen / nicht setzen → Default "*" (alle Origins erlaubt – nur lokal!)
CORS_ORIGIN=http://localhost:3000

# ─── Admin-API ────────────────────────────────────────────────────────────────
# Shared Secret für die Admin-Routen (/api/admin/*).
# Wird als X-Admin-Key Header übergeben.
# Nicht gesetzt → Admin-API antwortet mit 503 (deaktiviert, fail-closed).
# Produktion: langen, zufälligen String verwenden (z. B. openssl rand -hex 32)
ADMIN_SECRET=

# ─── Blog-API ─────────────────────────────────────────────────────────────────
# API-Key für POST /api/blog/posts (n8n Webhook / KI-Automation).
# Header: x-api-key: <BLOG_API_KEY>
# Nicht gesetzt → Webhook-Endpunkt antwortet mit 401.
# Produktion: langen, zufälligen String verwenden (z. B. openssl rand -hex 32)
BLOG_API_KEY=
