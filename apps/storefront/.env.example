# ─── Zahlungsoptionen ────────────────────────────────────────────────────────
# PayPal-Link (z. B. paypal.me/IhrName/betrag oder ein PayPal-Zahlungslink)
# Leer lassen → PayPal-Button wird als "nicht konfiguriert" angezeigt
NEXT_PUBLIC_PAYPAL_URL=https://paypal.me/IhrPayPalName

# ─── Storefront-URL (für Share-Links und SEO)
# Lokal:      http://localhost:3000
# Produktion: https://yourdomain.com
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# ─── Commerce API ──────────────────────────────────────────────────────────────
# URL des Hono-Backends (apps/commerce)
# Lokal:      http://localhost:3001
# Produktion: https://api.yourdomain.com
COMMERCE_API_URL=http://localhost:3001

# ─── Firebase Function – Lead-Ingestion ────────────────────────────────────────
# URL der deployten Firebase HTTP Function `onLeadSubmit`
# Leer lassen → Server Action fällt auf N8N_WEBHOOK_URL zurück (direkter Call)
# Produktion:  https://europe-west1-wsp-commerce.cloudfunctions.net/onLeadSubmit
FIREBASE_LEAD_FUNCTION_URL=

# ─── n8n – Webhook-Fallback ────────────────────────────────────────────────────
# Basis-URL der n8n-Instanz (ohne trailing slash)
# Wird genutzt, wenn FIREBASE_LEAD_FUNCTION_URL nicht gesetzt ist
# Lokal:      http://localhost:5678
# Produktion: https://n8n.yourdomain.com
N8N_WEBHOOK_URL=
